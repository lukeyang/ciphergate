GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCP_ARTIFACT_REPO=ciphergate

POLICY_SERVICE_NAME=ciphergate-policy-server
CUSTOMER_SERVICE_NAME=ciphergate-customer-app

# Optional: override customer app policy target.
# By default, deploy.sh wires POLICY_SERVER_URL to the freshly deployed policy-server URL.
# DEPLOY_POLICY_SERVER_URL=https://your-existing-policy-service.run.app

GEMINI_API_KEY=your_gemini_api_key
GEMINI_EMBED_MODEL=models/gemini-embedding-001
GEMINI_CHAT_MODEL=models/gemini-2.5-flash
GEMINI_CHAT_MODEL_FALLBACKS=models/gemini-2.5-pro,models/gemini-1.5-flash
GEMINI_CHAT_TIMEOUT_MS=7000
GEMINI_SUPPORT_PROMPT_FILE=prompts/support-agent.system.txt

# Optional policy tuning preset: default | strict | relaxed
# POLICY_PRESET=strict
